{
  "name": "@automatos/loader",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/widget.global.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./widget.js": "./dist/widget.global.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@automatos/core": "workspace:*",
    "@automatos/chat-widget": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.0"
  }
}
